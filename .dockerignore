# =============================================================================
# .dockerignore — Exclude unnecessary files from Docker build context
# =============================================================================
# Keeping the build context small means faster builds and smaller layers.

# ── Dependencies (installed fresh inside container) ──
node_modules
**/node_modules

# ── Next.js build artifacts (rebuilt in container) ──
.next
out

# ── Version control ──
.git
.gitignore
.gitattributes

# ── IDE / Editor ──
.vscode
.idea
*.swp
*.swo
*~

# ── OS files ──
.DS_Store
Thumbs.db

# ── Logs ──
*.log
dev.log
server.log
npm-debug.log*
bun-debug.log*

# ── Prisma generated artifacts (regenerated during build) ──
prisma/dev.db-journal

# ── Uploaded files (kept in image; persist via PVC in production if needed) ──
# public/uploads is NOT ignored — we want seed images available.

# ── Docker / K8s (no need to copy deployment files into image) ──
Dockerfile
docker-compose*.yml
.dockerignore
k8s/

# ── Documentation ──
README.md
WORKLOG.md
worklog.md
docs/

# ── Misc build / temp ──
tool-results/
agent-ctx/
download/
examples/
*.tgz
*.tar.gz

# ── IMPORTANT: Do NOT ignore these (needed at build/runtime) ──
# .env          — DATABASE_URL, ADMIN_SECRET_KEY, PRESENTER_KEY are read at build & runtime
# db/custom.db  — SQLite database (seeded data for the app)
# prisma/       — schema.prisma (needed for prisma generate + db push)
